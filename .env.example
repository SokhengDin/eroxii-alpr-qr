# ── Serial ────────────────────────────────────────────────────────────────────
# Windows: COM3, COM4, ...
# Linux:   /dev/ttyUSB0, /dev/ttyACM0, ...
SERIAL_PORT=COM3
BAUDRATE=9600
SERIAL_TIMEOUT=1
SERIAL_RETRY_SECONDS=3

# ── Duplicate suppression ──────────────────────────────────────────────────────
DUPLICATE_IGNORE_SECONDS=3

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# ── AI backend ─────────────────────────────────────────────────────────────────
AI_BASE_URL=http://localhost:8000
AI_PUSH_TIMEOUT=10
AI_PUSH_ENABLED=true
